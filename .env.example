# === Чувствительные данные (обязательно заполнить) ===

# Binance Futures API
# Testnet: https://testnet.binancefuture.com
# Mainnet: настройки Binance → API Management
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# Telegram (создать бота через @BotFather, получить chat_id через @userinfobot)
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# === Настройки стратегии ===

# Testnet (true) или Mainnet (false)
USE_TESTNET=true

# Реальное исполнение ордеров (true/false). По умолчанию false — только сигналы
ENABLE_TRADING=false

# Пороги Z-Score (опционально, для оптимизации после analyze_live_trades.py)
# Z_ENTRY_LONG=-2.0
# Z_ENTRY_SHORT=2.0
# Z_EXIT_TP_LONG=-0.5
# Z_EXIT_TP_SHORT=0.5
# Z_STOP_LOSS=4.0
